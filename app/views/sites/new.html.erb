<h2> Create Site </h2>
<% if @site.errors.present? %>
  <ul>
    <% @site.errors.full_messages.each do |error| %>
      <li><%= error %></li>
    <% end %>
  </ul>
<% end %>

<%= form_for(@site, url: sites_path(@site.id)) do |f| %>
  <p>
    <%= f.label 'Name' %>
    <%= f.text_field :name %>
  </p>
  <p>
    <%= f.label 'Location' %>
    <%= f.text_field :location %>
  </p>
  <p>
    <%= f.label 'sate' %>
    <%= f.text_field :state %>
  </p>
  <p>
    <%= f.label 'city' %>
    <%= f.text_field :city %>
  </p>
  <%= f.submit 'Create' %>
<% end %>